{
    "version": "0.12.4",
    "description": "专注于可扩展性和可用性的 Vim 复刻版",
    "homepage": "https://neovim.io/",
    "license": "Apache-2.0,Vim",
    "architecture": {
        "64bit": {
            "url": "https://github.com/neovim/neovim/releases/download/v0.12.4/nvim-win64.zip",
            "hash": "9fc3572829ffd13debb6e32555da2c8cc02555568260a9fc4cf1f65bbcca319c",
            "extract_dir": "nvim-win64"
        },
        "arm64": {
            "url": "https://github.com/neovim/neovim/releases/download/v0.12.4/nvim-win-arm64.zip",
            "hash": "49906085a3c473ee87a28319942c62216fb365a1a1a4f83dbc4ac41365f5e609",
            "extract_dir": "nvim-win-arm64"
        }
    },
    "pre_install": [
        "foreach ($folder in @('nvim', 'nvim-data')) {",
        "    $Software = \"$env:LOCALAPPDATA\\$folder\"; $SoftwarePersist = \"$persist_dir\\$folder\"",
        "    if (Test-Path $SoftwarePersist) { Remove-Item $Software -Force -Recurse -ErrorAction SilentlyContinue }",
        "    else { mkdir $Software -ErrorAction SilentlyContinue; Move-Item $Software $SoftwarePersist -Force }",
        "    New-Item -Type Junction -Path $Software -Target $SoftwarePersist | Out-Null }"
    ],
    "pre_uninstall": [
        "foreach ($folder in @('nvim', 'nvim-data')) {",
        "    $Software = \"$env:LOCALAPPDATA\\$folder\"",
        "    Remove-Item $Software -Force -Recurse -ErrorAction SilentlyContinue }"
    ],
    "bin": [
        "bin\\nvim.exe",
        "bin\\xxd.exe"
    ],
    "checkver": {
        "github": "https://github.com/neovim/neovim"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/neovim/neovim/releases/download/v$version/nvim-win64.zip"
            },
            "arm64": {
                "url": "https://github.com/neovim/neovim/releases/download/v$version/nvim-win-arm64.zip"
            }
        }
    }
}
